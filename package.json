{
  "name": "slate",
  "private": true,
  "version": "1.2.8",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "vue-tsc -b && electron-vite build",
    "build:electron": "npm run build && electron-builder",
    "build:mac": "npm run build && electron-builder --mac --publish never",
    "build:win": "npm run build && electron-builder --win --publish never",
    "build:linux": "npm run build && electron-builder --linux --publish never",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "vue": "^3.5.17",
    "vue-chartjs": "^5.3.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.13",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "electron-vite": "^5.0.0",
    "jsdom": "^26.1.0",
    "sass-embedded": "^1.92.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.10"
  },
  "description": "A free, canvas-based spreadsheet app for desktop.",
  "author": "Lorenzo Mazzola",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/larrydarko1/slate.git"
  },
  "build": {
    "appId": "com.slate.app",
    "productName": "Slate",
    "directories": {
      "output": "dist-electron"
    },
    "fileAssociations": [
      {
        "ext": "slate",
        "name": "Slate Spreadsheet",
        "description": "Slate Spreadsheet File",
        "mimeType": "application/x-slate",
        "role": "Editor",
        "icon": "build/slate"
      }
    ],
    "files": [
      "out/**/*",
      "node_modules/**/*"
    ],
    "dmg": {
      "background": "build/dmg-background.png",
      "icon": "build/icon.icns",
      "iconSize": 100,
      "iconTextSize": 14,
      "title": "${productName} ${version}",
      "window": {
        "width": 660,
        "height": 400
      },
      "contents": [
        {
          "x": 180,
          "y": 260
        },
        {
          "x": 480,
          "y": 260,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  }
}